<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ post.title }} — Simon Sorkin</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="{{ post.description }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #0d0d0c;
    --bg-soft:   #131311;
    --code-bg:   #1a1916;
    --fg:        #d6d2c6;
    --fg-strong: #ece9df;
    --soft:      #8a8478;
    --faint:     #5a554d;
    --rule:      #25231d;
    --accent:    #cf764a;

    --col:     640px;
    --img-col: 820px;

    --sans: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    --mono: 'IBM Plex Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;
  }

  *, *::before, *::after { box-sizing: border-box; }

  html, body {
    margin: 0; padding: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--sans);
    font-size: 17px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }
  ::selection { background: var(--accent); color: var(--bg); }

  /* ==================================================================
     LINK TAXONOMY — four tiers, weakest to strongest.
     ------------------------------------------------------------------
     T0  Bare      Typography signals clickability. No chrome at rest.
                   Hover: accent border-bottom appears.
                   Used on: header.bio .name, .post-title.

     T1  Quiet     Small inline nav / utility links.
                   Rest: --rule border. Hover: --accent border + --fg-strong text.
                   Used on: header.bio nav, .end-strip, a.continue.

     T2  Prose     Links inside running body text. Default <a>.
                   Rest: underline in --faint. Hover: --accent.

     T3  Emphasis  Max one per context. Draws the eye.
                   Rest: --accent border. Hover: text shifts to --accent.
                   Used on: .project a.

     Hover always lands on --accent. No exceptions.
     ================================================================== */

  /* T2 — default prose link */
  a {
    color: var(--fg-strong);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: var(--faint);
    transition: text-decoration-color 120ms ease, color 120ms ease;
  }
  a:hover { text-decoration-color: var(--accent); color: var(--fg-strong); }

  main {
    max-width: var(--col);
    margin: 0 auto;
    padding: 96px 32px 128px;
  }

  /* ---- persistent bio header (mirrors index.html) ------------------ */
  header.bio {
    padding-bottom: 28px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 88px;
  }
  header.bio .name {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 18px;
    color: var(--fg-strong);
    letter-spacing: -0.005em;
    margin: 0 0 10px;
  }
  header.bio .name a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color 160ms ease;
  }
  header.bio .name a:hover { border-bottom-color: var(--accent); }
  header.bio .name .alias {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 400;
    color: var(--soft);
    margin-left: 10px;
  }
  header.bio p {
    margin: 0 0 16px;
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--fg);
    max-width: 56ch;
  }
  header.bio .status {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 22px;
    font-family: var(--sans);
    font-size: 14.5px;
    font-weight: 500;
    color: var(--fg-strong);
    letter-spacing: -0.005em;
  }
  header.bio .status::before {
    content: "";
    display: inline-block;
    width: 7px;
    height: 7px;
    background: var(--accent);
    flex: 0 0 auto;
  }
  header.bio nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    font-family: var(--mono);
    font-size: 13px;
  }
  header.bio nav a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
    transition: border-color 120ms ease, color 120ms ease;
  }
  header.bio nav a:hover { border-color: var(--accent); color: var(--fg-strong); }

  /* ---- post header ------------------------------------------------- */
  .pmeta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
    font-family: var(--mono);
    font-size: 12px;
  }
  .pmeta time { color: var(--soft); }
  .pmeta .read { color: var(--soft); margin-left: auto; }

  h1.title {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 38px;
    line-height: 1.15;
    letter-spacing: -0.022em;
    color: var(--fg-strong);
    margin: 0 0 22px;
    max-width: 30ch;
  }

  /* project + stack rows */
  .project {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin: 0 0 18px;
    font-family: var(--mono);
    font-size: 13px;
  }
  .project .lbl {
    color: var(--soft);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 500;
    font-size: 11px;
  }
  .project a {
    color: var(--fg-strong);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .project a:hover { color: var(--accent); }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin: 0 0 36px;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--soft);
  }
  .stack span:not(:last-child)::after {
    content: "·";
    margin-left: 14px;
    color: var(--faint);
  }

  .lede {
    font-style: italic;
    font-weight: 300;
    font-size: 19px;
    line-height: 1.55;
    color: var(--fg);
    margin: 0 0 48px;
    max-width: 56ch;
  }

  /* ---- section headings -------------------------------------------- */
  article h2 {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.3;
    letter-spacing: -0.012em;
    color: var(--fg-strong);
    margin: 64px 0 22px;
    max-width: 28ch;
  }

  /* ---- body prose -------------------------------------------------- */
  article p {
    margin: 0 0 22px;
    font-size: 16.5px;
    line-height: 1.75;
    color: var(--fg);
  }

  article code {
    font-family: var(--mono);
    font-size: 0.88em;
    color: var(--fg-strong);
    background: var(--code-bg);
    padding: 1px 6px;
    border-radius: 2px;
    border: 1px solid var(--rule);
  }

  /* ---- figures ----------------------------------------------------- */
  figure {
    margin: 40px calc((var(--col) - var(--img-col)) / 2) 36px;
    max-width: var(--img-col);
  }
  figure img {
    display: block;
    width: 100%;
    height: auto;
    background: var(--bg-soft);
    border: 1px solid var(--rule);
  }
  figure figcaption {
    font-family: var(--sans);
    font-style: italic;
    font-weight: 300;
    font-size: 14px;
    line-height: 1.55;
    color: var(--soft);
    margin-top: 14px;
    padding: 0 calc((var(--img-col) - var(--col)) / 2);
    max-width: var(--col);
  }

  /* ---- end-of-post --------------------------------------------------*/
  .end-rule {
    margin: 96px 0 32px;
    border: 0;
    height: 1px;
    background: var(--rule);
  }
  .end-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--soft);
  }
  .end-strip a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
  }
  .end-strip a:hover { border-color: var(--accent); color: var(--fg-strong); }

  /* ---- responsive --------------------------------------------------- */
  @media (max-width: 760px) {
    :root { --img-col: 100%; }
    main { padding: 32px 22px 96px; }
    .top { margin-bottom: 56px; padding-bottom: 16px; }
    h1.title { font-size: 30px; }
    .lede { font-size: 17px; margin-bottom: 36px; }
    article h2 { font-size: 20px; margin-top: 48px; }
    article p { font-size: 16px; }
    figure { margin: 28px 0 22px; }
    figure figcaption { padding: 0; }
  }
</style>
</head>
<body>

<main>

{% include "_bio.html.j2" %}
  <article>

    <header>
      <div class="pmeta">
        <time datetime="{{ post.date_iso }}">{{ post.date_display }}</time>
        <span class="read">{{ post.read_time }} min read</span>
      </div>

      <h1 class="title">{{ post.title }}</h1>

      <div class="project">
        <span class="lbl">Project ↗</span>
        <a href="{{ post.project_url }}" target="_blank" rel="noopener">{{ post.project_url_display }}</a>
      </div>

      <div class="stack">
{% for chip in post.stack %}        <span>{{ chip }}</span>
{% endfor %}      </div>

      <p class="lede">{{ post.lede_html }}</p>
    </header>

{{ post.body_html }}

  </article>

  <hr class="end-rule">

  <div class="end-strip">
    <a href="index.html">← all writing</a>
    <span>Simon Sorkin · simon.sorkin@outlook.com</span>
  </div>

</main>

</body>
</html>
